{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VMAF JSON output",
  "description": "libvmaf log_fmt=json output. Top-level structure is stable; metrics inside frames vary by model/feature configuration.",
  "type": "object",
  "required": ["version", "fps", "frames", "pooled_metrics"],
  "properties": {
    "version": {
      "type": "string",
      "description": "libvmaf version hash"
    },
    "fps": {
      "type": "number",
      "description": "VMAF computation speed in frames per second. Unrelated to the video's framerate."
    },
    "frames": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["frameNum", "metrics"],
        "properties": {
          "frameNum": {
            "type": "integer",
            "minimum": 0
          },
          "metrics": {
            "type": "object",
            "description": "Per-frame metric values. Keys vary by libvmaf model and feature configuration. At least one VMAF score is always present.",
            "properties": {
              "vmaf":          { "type": "number", "description": "VMAF score (0-100), default/NHD model" },
              "vmaf_hd":       { "type": "number", "description": "VMAF HD model score (libvmaf: version=vmaf_v0.6.1:name=vmaf_hd)" },
              "vmaf_hd_neg":   { "type": "number", "description": "VMAF HD NEG model score (libvmaf: version=vmaf_v0.6.1neg:name=vmaf_hd_neg)" },
              "vmaf_hd_phone": { "type": "number", "description": "VMAF HD phone model score (libvmaf: version=vmaf_v0.6.1:name=vmaf_hd_phone:enable_transform=true)" },
              "vmaf_4k":       { "type": "number", "description": "VMAF 4K model score (libvmaf: version=vmaf_4k_v0.6.1:name=vmaf_4k)" },

              "integer_adm2":          { "type": "number", "description": "ADM (detail metric) level-2" },
              "integer_adm2_egl_1":    { "type": "number", "description": "ADM level-2 with EGL upsampling" },
              "integer_adm3":          { "type": "number", "description": "ADM level-3" },
              "integer_adm3_egl_1":    { "type": "number", "description": "ADM level-3 with EGL upsampling" },
              "integer_adm_scale0":    { "type": "number", "description": "ADM scale-0" },
              "integer_adm_scale0_egl_1": { "type": "number", "description": "ADM scale-0 with EGL upsampling" },
              "integer_adm_scale1":    { "type": "number", "description": "ADM scale-1" },
              "integer_adm_scale1_egl_1": { "type": "number", "description": "ADM scale-1 with EGL upsampling" },
              "integer_adm_scale2":    { "type": "number", "description": "ADM scale-2" },
              "integer_adm_scale2_egl_1": { "type": "number", "description": "ADM scale-2 with EGL upsampling" },
              "integer_adm_scale3":    { "type": "number", "description": "ADM scale-3" },
              "integer_adm_scale3_egl_1": { "type": "number", "description": "ADM scale-3 with EGL upsampling" },

              "integer_aim":        { "type": "number", "description": "AIM (temporal information metric)" },
              "integer_aim_egl_1":  { "type": "number", "description": "AIM with EGL upsampling" },

              "integer_vif_scale0": { "type": "number", "description": "VIF (information fidelity) scale-0" },
              "integer_vif_scale0_egl_1": { "type": "number", "description": "VIF scale-0 with EGL upsampling" },
              "integer_vif_scale1": { "type": "number", "description": "VIF scale-1" },
              "integer_vif_scale1_egl_1": { "type": "number", "description": "VIF scale-1 with EGL upsampling" },
              "integer_vif_scale2": { "type": "number", "description": "VIF scale-2" },
              "integer_vif_scale2_egl_1": { "type": "number", "description": "VIF scale-2 with EGL upsampling" },
              "integer_vif_scale3": { "type": "number", "description": "VIF scale-3" },
              "integer_vif_scale3_egl_1": { "type": "number", "description": "VIF scale-3 with EGL upsampling" },

              "integer_motion":     { "type": "number", "description": "Motion score" },
              "integer_motion2":    { "type": "number", "description": "Motion score variant-2" },
              "integer_motion3":    { "type": "number", "description": "Motion score variant-3" },

              "psnr_y":  { "type": "number", "description": "PSNR luminance (Y)" },
              "psnr_cb": { "type": "number", "description": "PSNR blue-difference chroma (Cb)" },
              "psnr_cr": { "type": "number", "description": "PSNR red-difference chroma (Cr)" },

              "float_ssim":    { "type": "number", "description": "Structural Similarity (SSIM)" },
              "float_ms_ssim": { "type": "number", "description": "Multi-Scale SSIM" },
              "cambi":         { "type": "number", "description": "Contrast Aware Multiscale Banding Index (CAMBI)" }
            },
            "additionalProperties": {
              "type": "number",
              "description": "Catch-all for any additional numeric metric emitted by newer or custom libvmaf builds"
            }
          }
        }
      }
    },
    "pooled_metrics": {
      "type": "object",
      "description": "Aggregate stats per metric. Keys mirror frame-level metrics but not all must be present.",
      "additionalProperties": {
        "type": "object",
        "required": ["min", "max", "mean", "harmonic_mean"],
        "properties": {
          "min":          { "type": "number" },
          "max":          { "type": "number" },
          "mean":         { "type": "number" },
          "harmonic_mean": { "type": "number" }
        }
      }
    },
    "aggregate_metrics": {
      "type": "object",
      "description": "Usually empty; reserved by libvmaf"
    }
  }
}
